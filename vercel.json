{
  "rewrites": [
    {
      "source": "/management-apps",
      "destination": "/management-apps/index.html"
    },
    {
      "source": "/management-apps/",
      "destination": "/management-apps/index.html"
    },
    {
      "source": "/management-apps/(.*)",
      "destination": "/management-apps/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
